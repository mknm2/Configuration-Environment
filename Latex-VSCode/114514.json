{
    // ========== 编译工具配置 ==========
    "latex-workshop.latex.tools": [
        {
            "name": "latexmk-xelatex",
            "command": "latexmk",
            "args": [
                "-xelatex",
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "%DOC%"
            ]
        },
        {
            "name": "latexmk-pdflatex",
            "command": "latexmk",
            "args": [
                "-pdf",
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "%DOC%"
            ]
        },
        {
            "name": "latexmk-lualatex",
            "command": "latexmk",
            "args": [
                "-lualatex",
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "%DOC%"
            ]
        },
        {
            "name": "xelatex-shell-escape",
            "command": "xelatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-shell-escape",
                "%DOCFILE%"
            ]
        }
    ],

    // ========== 编译链（Recipes） ==========
    "latex-workshop.latex.recipes": [
        {
            "name": "▶ 1. 智能全自动 (XeLaTeX - 日常/中文推荐)",
            "tools": ["latexmk-xelatex"]
        },
        {
            "name": "▶ 2. 智能全自动 (PdfLaTeX - 期刊会议模板)",
            "tools": ["latexmk-pdflatex"]
        },
        {
            "name": "▶ 3. 智能全自动 (LuaLaTeX - 复杂字体/多语言)",
            "tools": ["latexmk-lualatex"]
        },
        {
            "name": "▶ 4. 特殊编译 (XeLaTeX + minted 代码高亮)",
            "tools": ["xelatex-shell-escape"]
        }
    ],

    // ========== 清理辅助文件（避开了 synctex.gz） ==========
    "latex-workshop.latex.clean.fileTypes": [
        "*.aux", "*.bbl", "*.blg", "*.idx", "*.ind", "*.lof", "*.lot", 
        "*.out", "*.toc", "*.acn", "*.acr", "*.alg", "*.glg", "*.glo", 
        "*.gls", "*.ist", "*.fls", "*.log", "*.fdb_latexmk",
        "*.run.xml", "*.bcf", "*.nav", "*.snm", "*.vrb", "*.pyg"
    ],

    // ========== 编译与清理行为 ==========
    "latex-workshop.latex.autoClean.run": "onBuilt",
    "latex-workshop.latex.recipe.default": "first", // 固定使用第一个食谱（XeLaTeX智能编译）
    "latex-workshop.latex.autoBuild.run": "onSave", // 依然建议保存时才触发，保护电脑性能

    // ========== 视图与反向定位 ==========
    "latex-workshop.view.pdf.viewer": "tab",
    "latex-workshop.view.pdf.internal.synctex.keybinding": "double-click",

    // ========== 错误提示与补全 ==========
    "latex-workshop.message.error.show": true,
    "latex-workshop.message.warning.show": true,
    "latex-workshop.showContextMenu": true,
    "latex-workshop.intellisense.package.enabled": true
}