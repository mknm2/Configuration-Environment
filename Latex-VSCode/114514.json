{
    // ========== 编译工具 ==========
    "latex-workshop.latex.tools": [

        {
            "name": "xelatex",
            "command": "xelatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "%DOCFILE%"
            ]
        },

        {
            "name": "pdflatex",
            "command": "pdflatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "%DOCFILE%"
            ]
        },

        {
            "name": "lualatex",
            "command": "lualatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "%DOCFILE%"
            ]
        },

        {
            "name": "bibtex",
            "command": "bibtex",
            "args": [
                "%DOCFILE%"
            ]
        },

        {
            "name": "biber",
            "command": "biber",
            "args": [
                "%DOCFILE%"
            ]
        }

    ],

    // ========== 编译链（食谱） ==========
    "latex-workshop.latex.recipes": [

        {
            "name": "▶ XeLaTeX（单次编译）",
            "tools": [
                "xelatex"
            ]
        },

        {
            "name": "▶ XeLaTeX + Biber（完整编译）",
            "tools": [
                "xelatex",
                "biber",
                "xelatex",
                "xelatex"
            ]
        },

        {
            "name": "▶ XeLaTeX + BibTeX（完整编译）",
            "tools": [
                "xelatex",
                "bibtex",
                "xelatex",
                "xelatex"
            ]
        },

        {
            "name": "▶ PdfLaTeX（单次编译）",
            "tools": [
                "pdflatex"
            ]
        },

        {
            "name": "▶ PdfLaTeX + BibTeX（完整编译）",
            "tools": [
                "pdflatex",
                "bibtex",
                "pdflatex",
                "pdflatex"
            ]
        },

        {
            "name": "▶ LuaLaTeX + Biber（完整编译）",
            "tools": [
                "lualatex",
                "biber",
                "lualatex",
                "lualatex"
            ]
        }

    ],

    // ========== 清理文件类型 ==========
    "latex-workshop.latex.clean.fileTypes": [
        "*.aux",
        "*.bbl",
        "*.blg",
        "*.idx",
        "*.ind",
        "*.lof",
        "*.lot",
        "*.out",
        "*.toc",
        "*.acn",
        "*.acr",
        "*.alg",
        "*.glg",
        "*.glo",
        "*.gls",
        "*.ist",
        "*.fls",
        "*.log",
        "*.fdb_latexmk",
        "*.synctex.gz",
        "*.synctex(busy)",
        "*.run.xml",
        "*.bcf",
        "*.nav",
        "*.snm",
        "*.vrb",
        "*.pyg"
    ],

    // ========== PDF 查看器 ==========
    // 可选值: "none" | "browser" | "tab" | "external"
    "latex-workshop.view.pdf.viewer": "tab",

    // 反向同步：双击 PDF 跳转到源码（可选 "ctrl-click" | "double-click"）
    "latex-workshop.view.pdf.internal.synctex.keybinding": "double-click",

    // ========== 编译行为 ==========
    // 保存文件时自动编译
    "latex-workshop.latex.autoBuild.run": "onFileChange",

    // 默认编译链（上次使用的）
    "latex-workshop.latex.recipe.default": "lastUsed",

    // 自动清理：编译成功后自动删除辅助文件
    "latex-workshop.latex.autoClean.run": "onBuilt",

    // ========== 提示与补全 ==========
    // 显示编译错误
    "latex-workshop.message.error.show": true,

    // 显示编译警告
    "latex-workshop.message.warning.show": true,

    // 右键菜单：（1）编译文件；（2）定位游标
    "latex-workshop.showContextMenu": true,

    // 根据使用的宏包自动补全命令和环境
    "latex-workshop.intellisense.package.enabled": true

}
